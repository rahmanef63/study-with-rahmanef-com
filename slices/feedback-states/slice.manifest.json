{
  "$schema": "https://resource.rahmanef.com/slice-manifest-schema.json",
  "slug": "feedback-states",
  "version": "0.2.0",
  "tier": 3,
  "distribution": {
    "method": "cli-copy",
    "command": "npx rr add feedback-states",
    "consumerPath": "slices/feedback-states"
  },
  "files": [
    "README.md",
    "config.ts",
    "index.ts",
    "variants/empty/components/EmptyState.tsx",
    "variants/empty/components/ErrorPage.tsx",
    "variants/empty/components/presets.ts",
    "variants/empty/index.ts",
    "variants/loading/components/LoadingSkeleton.tsx",
    "variants/loading/components/LoadingState.tsx",
    "variants/loading/components/presets.ts",
    "variants/loading/index.ts"
  ],
  "imports": {
    "shared": [],
    "external": []
  }
}
