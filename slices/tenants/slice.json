{
  "$schema": "https://resource.rahmanef.com/slice-schema.json",
  "slug": "tenants",
  "version": "0.2.0",
  "category": "community",
  "title": "Tenants — community profile, join flow, memberships, roles & requests",
  "description": "Multi-tenant community layer for belajar-with-rahmanef.com (STATUS.md #1 + #6): public tenant profile (/t/[slug] etalase), idempotent join-as-member flow, membership/role data layer (owner/instructor/member), owner settings form, and (v1.1) the community request flow (/buka-komunitas) plus the platform-admin approval queue (/admin/komunitas). Discord webhook URL is write-only: accepted by updateProfile, never present in any query result (P0). Reject reuses status 'suspended' (schema has no 'rejected' literal).",
  "namespace": "@/features/tenants",
  "convex": {
    "schemaPath": "convex/schema.ts",
    "rootPaths": ["convex/features/tenants"]
  },
  "deps": {
    "npm": [],
    "shadcn": ["button", "card", "input", "label", "skeleton", "empty"],
    "env": [],
    "peers": []
  },
  "audit": ["bp:public-fn-validator"],
  "license": "MIT",
  "tags": ["multi-tenant", "community", "membership", "roles", "convex", "bahasa-indonesia"],
  "contract": {
    "requires": {
      "auth": "convex",
      "slices": ["responsive-dialog"],
      "convex": {
        "tables": ["tenants", "memberships", "profiles", "users"],
        "helpers": ["requireUser", "requireTenantRole", "requirePlatformAdmin"]
      }
    },
    "provides": {
      "routesExpected": [
        "/t/[slug]",
        "/t/[slug]/kelola/komunitas",
        "/buka-komunitas",
        "/admin/komunitas"
      ],
      "components": [
        "TenantHomeView",
        "TenantSettingsView",
        "JoinButton",
        "MembersList",
        "TenantProfileCard",
        "TenantProfileForm",
        "RoleChip",
        "RequestTenantForm",
        "AdminTenantQueueView"
      ],
      "hooks": [
        "useTenantBySlug",
        "useActiveTenants",
        "useMyMembership",
        "useTenantMembers",
        "useTenantManageView",
        "useJoinTenant",
        "useUpdateTenantProfile",
        "useSetMemberRole",
        "useRequestTenant",
        "useApproveTenant",
        "useRejectTenant",
        "useAdminPendingTenants",
        "useMyPlatformAdmin"
      ],
      "helpers": ["tenantsApi", "errorToCopy", "extractErrorCode"],
      "convexFunctions": [
        "features/tenants/queries:getPublicBySlug",
        "features/tenants/queries:listActive",
        "features/tenants/queries:getManageView",
        "features/tenants/members:getMyMembership",
        "features/tenants/members:listMembers",
        "features/tenants/mutations:join",
        "features/tenants/mutations:updateProfile",
        "features/tenants/mutations:setMemberRole",
        "features/tenants/requests:requestTenant",
        "features/tenants/admin:listPending",
        "features/tenants/admin:approve",
        "features/tenants/admin:reject",
        "features/tenants/admin:getMyPlatformAdmin"
      ]
    },
    "generalization": {
      "level": "project-specific"
    }
  }
}
