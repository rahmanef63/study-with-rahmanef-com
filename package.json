{
  "name": "belajar-with-rahmanef",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "convex:dev": "convex dev",
    "convex:codegen": "convex dev --once",
    "build:auto": "if [ -n \"$CONVEX_DEPLOY_KEY\" ]; then node scripts/setup-auth.mjs && convex deploy --cmd 'next build'; else next build; fi",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:staging": "cross-env E2E_BASE_URL=https://study-with.rahmanef.com playwright test",
    "e2e:prod": "playwright test"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.18.0",
    "input-otp": "^1.4.2",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "radix-ui": "^1.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.8.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "convex-test": "^0.0.54",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
